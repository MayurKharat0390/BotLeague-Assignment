# -----------------------------------------------------------------------------
# BOTLEAGUE DATABASE CONFIGURATION
# Copy this file to '.env' and fill in your database credentials.
# -----------------------------------------------------------------------------

# Supabase PostgreSQL Database credentials
# Retrieve these from your Supabase Dashboard -> Project Settings -> API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-service-role-or-anon-key

# Resend Email Service credentials (optional - for welcome/confirmation emails)
# Retrieve this from your Resend.com Dashboard -> API Keys
RESEND_API_KEY=re_your_api_key

# Brevo Email Service (optional - sends emails to ANY recipient for free in sandbox mode)
# Retrieve API key from Brevo.com -> SMTP & API Keys
BREVO_API_KEY=xkeysib-xxxxxxxxx
BREVO_SENDER_EMAIL=your_verified_brevo_sender@email.com


